{
  "name": "maxnijenkamp/laravel-package-starter-kit",
  "description": "Artisan-powered starter kit to scaffold Laravel packages (folders, service provider, config, tests, CI, and more) with interactive options.",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "laravel",
    "package",
    "starter kit",
    "scaffolding",
    "generator"
  ],
  "authors": [
    {
      "name": "Max Nijenkamp"
    }
  ],
  "require": {
    "php": "^8.1",
    "illuminate/support": "^10.0|^11.0|^12.0"
  },
  "autoload": {
    "psr-4": {
      "MaxNijenkamp\\\\LaravelPackageStarterKit\\\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "MaxNijenkamp\\\\LaravelPackageStarterKit\\\\Tests\\\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "MaxNijenkamp\\\\LaravelPackageStarterKit\\\\StarterKitServiceProvider"
      ]
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
